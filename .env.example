# Copy to ``.env`` and fill in.  The file is git-ignored.

# DeepSeek API key — required to run the LLM decision fuser.
# Get one at https://platform.deepseek.com/
DEEPSEEK_API_KEY=

# Optional overrides (defaults shown).
# DEEPSEEK_BASE_URL=https://api.deepseek.com/v1
# DEEPSEEK_MODEL=deepseek-chat            # alternative: deepseek-reasoner

# Process-wide guard rail on token spend.  500k tokens ≈ ¥0.5 / day at deepseek-chat
# prices.  When the budget is hit, llm_client raises LLMBudgetExceeded and the
# strategy falls back to the rule-only path.
# LLM_DAILY_TOKEN_BUDGET=500000

# LLM_REQUEST_TIMEOUT=60

# --- Server deploy (local .env only, never commit password) ---
# ETF_SERVER_HOST=39.105.104.230
# ETF_SERVER_USER=ciyuan
# ETF_SERVER_PASSWORD=
# ETF_SERVER_REMOTE=/home/ciyuan/chenjunren/etf_agent

# --- Public endpoint guards (dashboard /api/run, chat API) ---
# ETF_RUN_TOKEN=your-secret-token-here
# ETF_RUN_MAX_PER_WINDOW=3
# ETF_RUN_WINDOW_SEC=7200
# ETF_RUN_MIN_INTERVAL_SEC=180
# ETF_CHAT_MAX_PER_WINDOW=20
# ETF_CHAT_WINDOW_SEC=600
# ETF_CHAT_MIN_INTERVAL_SEC=2
